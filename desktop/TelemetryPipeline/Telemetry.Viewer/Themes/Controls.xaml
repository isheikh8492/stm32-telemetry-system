<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="SidebarSectionStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="SidebarHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Background" Value="{StaticResource PanelHeaderBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PanelHeaderForegroundBrush}" />
    </Style>

    <Style x:Key="SidebarSectionBodyStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="10" />
    </Style>

    <Style x:Key="SidebarFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="SidebarComboBoxStyle" TargetType="ComboBox">
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="28" />
    </Style>

    <Style x:Key="SidebarCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="PlotHostBorderStyle" TargetType="Border">
        <Setter Property="Width" Value="900" />
        <Setter Property="Height" Value="520" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource WorksheetSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PlotBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
</ResourceDictionary>
