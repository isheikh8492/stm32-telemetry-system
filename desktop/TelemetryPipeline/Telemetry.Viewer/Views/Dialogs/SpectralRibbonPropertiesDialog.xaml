<Window
    x:Class="Telemetry.Viewer.Views.Dialogs.SpectralRibbonPropertiesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Spectral Ribbon Properties"
    Width="400"
    Height="540"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Top" Margin="0,0,0,8" Text="Channels:" />
        <ListBox
            x:Name="ChannelsListBox"
            Grid.Row="0"
            Grid.Column="2"
            Margin="0,0,0,8"
            SelectionMode="Multiple">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="2" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}">
                                    <CheckBox
                                        IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}"
                                        Content="{Binding Name}"
                                        VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,0,8" VerticalAlignment="Center" Text="Parameter:" />
        <ComboBox  x:Name="ParamComboBox" Grid.Row="1" Grid.Column="2" Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,0,8" VerticalAlignment="Center" Text="Bin count:" />
        <ComboBox  x:Name="BinCountComboBox" Grid.Row="2" Grid.Column="2" Margin="0,0,0,8" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,0,8" VerticalAlignment="Center" Text="Min range:" />
        <TextBox   x:Name="MinRangeBox" Grid.Row="3" Grid.Column="2" Margin="0,0,0,8" />

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,0,8" VerticalAlignment="Center" Text="Max range:" />
        <TextBox   x:Name="MaxRangeBox" Grid.Row="4" Grid.Column="2" Margin="0,0,0,8" />

        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,0,8" VerticalAlignment="Center" Text="Scale:" />
        <ComboBox  x:Name="ScaleComboBox" Grid.Row="5" Grid.Column="2" Margin="0,0,0,8" />

        <StackPanel
            Grid.Row="6"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="0,8,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Margin="0,0,8,0"
                Click="OkButton_Click"
                Content="OK"
                IsDefault="True" />
            <Button
                Width="80"
                Click="CancelButton_Click"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
