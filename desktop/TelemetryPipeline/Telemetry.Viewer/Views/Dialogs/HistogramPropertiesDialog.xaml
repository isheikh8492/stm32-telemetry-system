<Window
    x:Class="Telemetry.Viewer.Views.Dialogs.HistogramPropertiesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Histogram Properties"
    Width="320"
    Height="380"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,4" Text="Channel ID:" />
        <ComboBox x:Name="ChannelIdComboBox" Grid.Row="1" Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Margin="0,0,0,4" Text="Parameter:" />
        <ComboBox x:Name="ParamComboBox" Grid.Row="3" Margin="0,0,0,8" />

        <TextBlock Grid.Row="4" Margin="0,0,0,4" Text="Bin count:" />
        <ComboBox x:Name="BinCountComboBox" Grid.Row="5" Margin="0,0,0,8" />

        <TextBlock Grid.Row="6" Margin="0,0,0,4" Text="Min range:" />
        <TextBox x:Name="MinRangeBox" Grid.Row="7" Margin="0,0,0,8" />

        <TextBlock Grid.Row="8" Margin="0,0,0,4" Text="Max range:" />
        <TextBox x:Name="MaxRangeBox" Grid.Row="9" Margin="0,0,0,8" />

        <TextBlock Grid.Row="10" Margin="0,0,0,4" Text="Scale:" />
        <ComboBox x:Name="ScaleComboBox" Grid.Row="11" Margin="0,0,0,8" />

        <StackPanel
            Grid.Row="13"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Margin="0,0,8,0"
                Click="OkButton_Click"
                Content="OK"
                IsDefault="True" />
            <Button
                Width="80"
                Click="CancelButton_Click"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
