<Window
    x:Class="Telemetry.Viewer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Telemetry.Viewer.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:plots="clr-namespace:Telemetry.Viewer.Views.Plots"
    Title="Telemetry Viewer"
    Width="800"
    Height="450"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="17*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar with Control Panels (15%)  -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0">
                    <!--  Connection Panel  -->
                    <StackPanel Style="{StaticResource SidebarSectionStyle}">
                        <TextBlock Style="{StaticResource SidebarHeaderTextStyle}" Text="Connection" />
                        <StackPanel Style="{StaticResource SidebarSectionBodyStyle}">
                            <TextBlock Style="{StaticResource SidebarFieldLabelStyle}" Text="Port:" />
                            <ComboBox
                                IsEnabled="{Binding IsDisconnected}"
                                ItemsSource="{Binding AvailablePorts}"
                                SelectedItem="{Binding SelectedPort, Mode=TwoWay}"
                                Style="{StaticResource SidebarComboBoxStyle}" />
                            <TextBlock Style="{StaticResource SidebarFieldLabelStyle}" Text="Baud Rate:" />
                            <ComboBox
                                IsEnabled="{Binding IsDisconnected}"
                                ItemsSource="{Binding SupportedBaudRates}"
                                SelectedItem="{Binding SelectedBaudRate, Mode=TwoWay}"
                                Style="{StaticResource SidebarComboBoxStyle}" />
                            <Button
                                Command="{Binding ToggleConnectionCommand}"
                                Content="{Binding ConnectButtonText}"
                                Style="{StaticResource SidebarButtonStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Recording Panel  -->
                    <StackPanel Style="{StaticResource SidebarSectionStyle}">
                        <TextBlock Style="{StaticResource SidebarHeaderTextStyle}" Text="Recording" />
                        <StackPanel Style="{StaticResource SidebarSectionBodyStyle}">
                            <Button
                                Margin="0,0,0,6"
                                Content="Start Recording"
                                Style="{StaticResource SidebarButtonStyle}" />
                            <Button Content="Stop Recording" Style="{StaticResource SidebarButtonStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Display Settings Panel  -->
                    <StackPanel Style="{StaticResource SidebarSectionStyle}">
                        <TextBlock Style="{StaticResource SidebarHeaderTextStyle}" Text="Display Settings" />
                        <StackPanel Style="{StaticResource SidebarSectionBodyStyle}">
                            <CheckBox Content="Auto-scroll" Style="{StaticResource SidebarCheckBoxStyle}" />
                            <CheckBox Content="Show grid" Style="{StaticResource SidebarCheckBoxStyle}" />
                            <TextBlock Margin="0,6,0,4" Text="Update Rate (Hz):" />
                            <Slider
                                Maximum="60"
                                Minimum="1"
                                Value="30" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Processing Stats Panel  -->
                    <StackPanel Style="{StaticResource SidebarSectionStyle}">
                        <TextBlock Style="{StaticResource SidebarHeaderTextStyle}" Text="Processing Stats" />
                        <StackPanel Style="{StaticResource SidebarSectionBodyStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,0,8,2"
                                    Text="Event rate:" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,0,0,2"
                                    Text="{Binding EventRateText}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,0,8,2"
                                    Text="Processing:" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,0,0,2"
                                    Text="{Binding ProcessingTimeText}" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Text="Render:" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Text="{Binding RenderTimeText}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!--  GridSplitter for resizing  -->
        <GridSplitter
            Grid.Column="1"
            Width="5"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />

        <!--  Worksheet Area (85%)  -->
        <Border Grid.Column="2" Background="{StaticResource WorksheetSurfaceBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Toolbar  -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="10,6"
                    Background="{StaticResource WorksheetHeaderBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            MinWidth="140"
                            Margin="0,0,8,0"
                            Command="{Binding AddOscilloscopeCommand}"
                            Content="Add Oscilloscope" />
                    </StackPanel>
                </Border>

                <!--  Worksheet body — dynamic plots  -->
                <Border Grid.Row="1" Background="{StaticResource WorksheetSurfaceBrush}">
                    <ItemsControl ItemsSource="{Binding Plots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <plots:OscilloscopePlotView />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
