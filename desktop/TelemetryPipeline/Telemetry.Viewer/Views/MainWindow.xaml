<Window
    x:Class="Telemetry.Viewer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Telemetry.Viewer.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wks="clr-namespace:Telemetry.Viewer.Views.Worksheet"
    Title="Telemetry Viewer"
    Width="800"
    Height="450"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="17*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar with Control Panels (15%)  -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0">
                    <!--  Connection Panel  -->
                    <StackPanel Style="{StaticResource SidebarSectionStyle}">
                        <TextBlock Style="{StaticResource SidebarHeaderTextStyle}" Text="Connection" />
                        <StackPanel Style="{StaticResource SidebarSectionBodyStyle}">
                            <TextBlock Style="{StaticResource SidebarFieldLabelStyle}" Text="Port:" />
                            <ComboBox
                                IsEnabled="{Binding IsDisconnected}"
                                ItemsSource="{Binding AvailablePorts}"
                                SelectedItem="{Binding SelectedPort, Mode=TwoWay}"
                                Style="{StaticResource SidebarComboBoxStyle}" />
                            <TextBlock Style="{StaticResource SidebarFieldLabelStyle}" Text="Baud Rate:" />
                            <ComboBox
                                IsEnabled="{Binding IsDisconnected}"
                                ItemsSource="{Binding SupportedBaudRates}"
                                SelectedItem="{Binding SelectedBaudRate, Mode=TwoWay}"
                                Style="{StaticResource SidebarComboBoxStyle}" />
                            <Button Command="{Binding ToggleConnectionCommand}">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                                        <Setter Property="Content" Value="Connect" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Content" Value="Disconnect" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!--  Recording Panel  -->
                    <StackPanel Style="{StaticResource SidebarSectionStyle}">
                        <TextBlock Style="{StaticResource SidebarHeaderTextStyle}" Text="Recording" />
                        <StackPanel Style="{StaticResource SidebarSectionBodyStyle}">
                            <Button
                                Margin="0,0,0,6"
                                Content="Start Recording"
                                Style="{StaticResource SidebarButtonStyle}" />
                            <Button Content="Stop Recording" Style="{StaticResource SidebarButtonStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Display Settings Panel  -->
                    <StackPanel Style="{StaticResource SidebarSectionStyle}">
                        <TextBlock Style="{StaticResource SidebarHeaderTextStyle}" Text="Display Settings" />
                        <StackPanel Style="{StaticResource SidebarSectionBodyStyle}">
                            <CheckBox Content="Show grid" Style="{StaticResource SidebarCheckBoxStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Processing Stats Panel  -->
                    <StackPanel Style="{StaticResource SidebarSectionStyle}">
                        <TextBlock Style="{StaticResource SidebarHeaderTextStyle}" Text="Processing Stats" />
                        <StackPanel Style="{StaticResource SidebarSectionBodyStyle}">
                            <Grid>
                                <Grid.Resources>
                                    <Style x:Key="StatLabel" TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,3" />
                                    </Style>
                                    <Style x:Key="StatValue" TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,3" />
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="FontFamily" Value="Consolas" />
                                    </Style>
                                </Grid.Resources>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource StatLabel}"
                                    Text="Total events" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource StatValue}"
                                    Text="{Binding Stats.TotalEventsText}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource StatLabel}"
                                    Text="Event rate" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource StatValue}"
                                    Text="{Binding Stats.EventRateText}" />

                                <!-- Per-plot-type timings: each row matches the surrounding
                                     label/value pattern (type name left, "proc / render ms" right). -->
                                <ItemsControl Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                              ItemsSource="{Binding Stats.PlotStats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="7*" />
                                                    <ColumnDefinition Width="3*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Padding="6,3"
                                                           Text="{Binding Name}" />
                                                <TextBlock Grid.Column="1"
                                                           Padding="6,3"
                                                           HorizontalAlignment="Right"
                                                           FontFamily="Consolas"
                                                           Text="{Binding Value}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!--  Sidebar/worksheet splitter — wider hit area with a thin visible line  -->
        <GridSplitter
            Grid.Column="1"
            Width="5"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#BBB" />

        <!--  Worksheet Area (85%)  -->
        <Border Grid.Column="2" Background="{StaticResource WorksheetSurfaceBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Toolbar  -->
                <Border
                    Grid.Row="0"
                    Padding="10,6"
                    Background="{StaticResource WorksheetHeaderBrush}"
                    BorderBrush="#BBB"
                    BorderThickness="0,0,0,1">
                    <ItemsControl ItemsSource="{Binding Worksheet.PlotTypes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button
                                    MinWidth="140"
                                    Margin="0,0,8,0"
                                    Command="{Binding AddCommand}"
                                    Content="{Binding Label, StringFormat='Add {0}'}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!--  Worksheet body — UserControl owns the canvas + grid + plot interactions  -->
                <wks:WorksheetGrid Grid.Row="1" DataContext="{Binding Worksheet}" />
            </Grid>
        </Border>
    </Grid>
</Window>
