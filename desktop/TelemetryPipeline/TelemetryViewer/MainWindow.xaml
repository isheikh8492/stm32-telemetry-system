<Window
    x:Class="TelemetryViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TelemetryViewer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:scottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
    Title="Telemetry Viewer"
    Width="800"
    Height="450"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="17*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar with Control Panels (15%)  -->
        <Border Grid.Column="0" Background="#F5F5F5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0">
                    <!--  Connection Panel  -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock
                            Padding="10,8"
                            Background="#1F3B5C"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Connection" />
                        <StackPanel Margin="10">
                            <TextBlock Margin="0,0,0,4" Text="Port:" />
                            <ComboBox
                                x:Name="PortComboBox"
                                MinWidth="120"
                                Margin="0,0,0,10" />
                            <TextBlock Margin="0,0,0,4" Text="Baud Rate:" />
                            <ComboBox
                                x:Name="BaudRateComboBox"
                                MinWidth="120"
                                Margin="0,0,0,10"
                                IsEnabled="False" />
                            <Button
                                x:Name="ConnectButton"
                                Height="28"
                                Click="ConnectButton_Click"
                                Content="Connect" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Recording Panel  -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock
                            Padding="10,8"
                            Background="#1F3B5C"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Recording" />
                        <StackPanel Margin="10">
                            <Button
                                Height="28"
                                Margin="0,0,0,6"
                                Content="Start Recording" />
                            <Button Height="28" Content="Stop Recording" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Display Settings Panel  -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock
                            Padding="10,8"
                            Background="#1F3B5C"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Display Settings" />
                        <StackPanel Margin="10">
                            <CheckBox Margin="0,0,0,6" Content="Auto-scroll" />
                            <CheckBox Margin="0,0,0,6" Content="Show grid" />
                            <TextBlock Margin="0,6,0,4" Text="Update Rate (Hz):" />
                            <Slider
                                Maximum="60"
                                Minimum="1"
                                Value="30" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!--  GridSplitter for resizing  -->
        <GridSplitter
            Grid.Column="1"
            Width="5"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />

        <!--  Worksheet Area (85%)  -->
        <Border Grid.Column="2" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="13*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="10,6"
                    Background="#E9EEF5" />

                <Border Grid.Row="1" Background="#FFFFFF">
                    <Grid>
                        <Border
                            Width="900"
                            Height="520"
                            Padding="8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="White"
                            BorderBrush="#D7DEE8"
                            BorderThickness="1"
                            CornerRadius="8">
                            <scottPlot:WpfPlot x:Name="TelemetryPlot" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
